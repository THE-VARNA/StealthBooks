# Network resilience
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=300000

# Suppress peer dep overrides from transitive sub-trees (e.g. Umbra SDK internals)
# These conflicts are inside @umbra-privacy/sdk's own nested packages and cannot
# be fixed from our package.json. Using legacy-peer-deps avoids the ERESOLVE
# override spam while still resolving correctly.
legacy-peer-deps=true

# Reduce install noise
loglevel=warn
fund=false
