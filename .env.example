# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (local dev or cloud e.g. Neon, Supabase)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/stealthbooks"

# ─── Auth ───────────────────────────────────────────────────────────────────────
# iron-session secret — must be at least 32 characters, random
# Generate with: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-random-32-char-or-longer-string"

# ─── Solana ──────────────────────────────────────────────────────────────────────
# Target cluster: "mainnet-beta" | "devnet"
NEXT_PUBLIC_SOLANA_CLUSTER="mainnet-beta"

# Solana RPC endpoint (use a private RPC for production — Helius, QuickNode, etc.)
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"

# ─── Umbra SDK ────────────────────────────────────────────────────────────────────
# Umbra indexer API endpoint (official)
NEXT_PUBLIC_UMBRA_INDEXER_URL="https://utxo-indexer.api.umbraprivacy.com"

# Umbra relayer API endpoint (official)
NEXT_PUBLIC_UMBRA_RELAYER_URL="https://relayer.api.umbraprivacy.com"

# USDC mint address (SPL, 6 decimals)
# mainnet-beta: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# devnet:       4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU (wrapped, check active pools)
NEXT_PUBLIC_USDC_MINT="EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"

# ─── App ──────────────────────────────────────────────────────────────────────────
# Base URL for generating public checkout and disclosure links
# In development: http://localhost:3000
# In production: your deployed URL (e.g. https://stealthbooks.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Invoice checkout link token salt (rotate to invalidate all existing tokens)
# Generate with: openssl rand -hex 16
INVOICE_TOKEN_SALT="change-me-to-a-random-hex-string"
